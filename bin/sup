main () {
    local ret=0
    local parsed

    parsed="$(parse_options "$@")" || exit 64
    eval "$parsed"

    while :; do
        case "$1" in
            --)
                shift
                break
                ;;
            --report)
                shift
                if [ -z "$1" ]; then
                    echo "$0: option requires an argument -- report" >&2
                    exit 64
                fi
                OPT_report=$1
                ;;
            -e)
                # show error only
                OPT_e=t
                ;;
            -q)
                OPT_q=t
                ;;
            -r)
                OPT_r=t
                ;;
            *)
                break
                ;;
        esac
        shift
    done

    case "$(basename "$0")" in
        sup)
            unset MYTMPDIR
            setup
            setup_report
            sup "${@:-.}" || ret="$?"
            run_maintenance
            teardown
            return $ret
            ;;
        *)
            vcs "${@:-.}"
            ;;
    esac
}

parse_options () {
    git rev-parse --parseopt --stop-at-non-option -- "$@" <<EOF
sup [options] [<path>...]

--
e     show errors only
q     suppress warnings
r     update recursively
report=!file write update results
EOF
}

warn () {
    [ -n "$OPT_q" ] ||
        echo "$0: $*" >&2
}

sh_escape () {
    case "$*" in
        '')
            echo "''"
            ;;
        *[!A-Za-z0-9_.,:/@-]*)
            awk '
                BEGIN {
                    n = ARGC - 1
                    for (i = 1; i <= n; i++) {
                        s = ARGV[i]
                        if (s == "") {
                            s = "\047\047"
                        } else {
                            gsub(/[^\nA-Za-z0-9_.,:\/@-]/, "\\\\&", s)
                            gsub(/\n/, "\"\n\"", s)
                        }
                        printf "%s", s
                        if (i != n) printf " "
                    }
                    exit 0
                }
                ' "$@"
            ;;
        *)
            printf '%s' "$*" 
            ;;
    esac
}

dir_of () {
    local file="${1:-.}"; shift
    if [ -d "$file" ]; then
        echo "$file"
    else
        dirname "$file"
    fi
}

vcs_of () {
    local file="${1:-.}" dir; shift
    (
        dir="$(dir_of "$file")"

        cd "$dir" || exit

        if [ -f config -a -d objects -a -d refs ]; then
            case "$dir" in
                ?*.git)
                    echo git-bare
                    exit
                    ;;
            esac
        fi

        (
        while :; do
            if [ -d .git ]; then
                if [ -d .git/svn ]; then
                    if [ -z "$(find .git/svn -type f -print)" ]; then
                        rm -rf .git/svn
                        echo git
                    else
                        echo git-svn
                    fi
                else
                    echo git
                fi
                exit
            elif [ -f .git ]; then
                echo git
                exit
            elif [ -d .hg ]; then
                echo hg
                exit
            elif [ -d .bzr ]; then
                echo bzr
                exit
            elif [ -d .svn ]; then
                echo svn
                exit
            fi

            if [ "$(pwd)" = / ]; then
                break
            fi
            cd -P ..
        done
        )

        if [ -d CVS ]; then
            echo cvs
            exit
        fi

        exit 1
    )
}

setup () {
    if [ -n "$MYTMPDIR" ]; then
        MYTMPDIR=$(mktemp -d "${MYTMPDIR}/XXXXXX")
    else
        MYTMPDIR=$(mktemp -d "${TMPDIR-/tmp}/${0##*/}.XXXXXX")
    fi
    trap 'teardown' 0 1 2 3 15
}

teardown () {
    rm -rf "$MYTMPDIR"
}

handle_status () {
    local ret=$1

    [ -n "$ret" ] || return

    if [ $ret -gt 128 ]; then
        if [ $ret -le 165 ]; then
            kill -$((ret - 128)) $$
            sleep 3
        fi
        exit $ret
    fi
}

sup () {
    local file ret=0 dir

    for file; do
        sup_1 "$(vcs_of "$file")" "$file" || ret="$?"
        handle_status $ret
        if [ -n "$OPT_r" -a -f "$file/.sup" ]; then
            eval "sup $(subdirs_escaped "$file")" || ret="$?"
            handle_status $ret
        fi
    done

    return $ret
}

sup_1 () {
    local vcs="$1" file="$2" ret=0

    if [ -n "$OPT_e" ]; then
        local logfile="$(mktemp "$MYTMPDIR"/log.XXXXXX)"
        do_sup "$@" </dev/null >"$logfile" 2>&1 || ret="$?"
        [ "$ret" -eq 0 ] || cat "$logfile"
    else
        do_sup "$@" || ret="$?"
    fi

    report_status "$file" "$vcs" "$ret"

    return $ret
}

do_sup () {
    local vcs="$1" file="$2"
    local dir="$(dir_of "$file")"
    local ret=0

    if [ -z "$vcs" ]; then
        if [ -n "$OPT_e" ]; then
            return 0
        else
            warn "VCS unknown: $file"
            return 1
        fi
    fi

    case "$vcs" in
        svn)
            echo "[Updating \`$file' with $vcs]"
            ( setup; svn_upgrade "$file"; svn_update "$file" )
            ;;
        cvs)
            echo "[Updating \`$file' with $vcs]"
            if [ -d "$file" ]; then
                ( setup; cd "$file" && cvs update )
            else
                ( setup; cd "$dir" && cvs update "$(basename "$file")" )
            fi
            ;;
        git|git-svn)
            if [ "$vcs" = git ]; then
                echo "[Updating \`$file' with $vcs]"
            else
                echo "[Updating \`$file' with git + $vcs]"
            fi
            record_maintenance_target "$dir"
            ( setup; cd "$dir" && {
                    if [ "$vcs" = git-svn ]; then
                        git svn fetch || exit
                    fi
                    old_default_remote="$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null)"
                    update_log="$(mktemp "$MYTMPDIR"/git-update.XXXXXX)"
                    update_failed=
                    if git_remote_update 2>"$update_log"; then
                        :
                    else
                        ret=$?
                        update_failed=t
                        if [ "$ret" -eq 127 ]; then
                            cat "$update_log" >&2
                            exit 0
                        fi
                    fi
                    local="$(git symbolic-ref HEAD 2>/dev/null)"
                    if [ -n "$local" ]; then
                        remote="$(git for-each-ref --format='%(upstream:short)' "$local" 2>/dev/null)"
                        git remote set-head origin --auto >/dev/null 2>&1 || :
                        default_remote="$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null)"
                        # Recover from an already-pruned default branch when the old origin/HEAD is dangling.
                        if [ "$default_remote" = "$old_default_remote" ] &&
                               [ "$remote" = "$old_default_remote" ] &&
                               ! git rev-parse --verify -q "$old_default_remote^{commit}" >/dev/null
                        then
                            default_remote=
                            for candidate in $(git for-each-ref --format='%(refname:short)' refs/remotes/origin); do
                                if [ "$candidate" != origin/HEAD ] &&
                                       git merge-base --is-ancestor "$local" "$candidate" 2>/dev/null
                                then
                                    if [ -n "$default_remote" ]; then
                                        default_remote=
                                        break
                                    fi
                                    default_remote="$candidate"
                                fi
                            done
                        fi
                        # Follow the renamed remote default branch when the current branch tracked the old one.
                        if [ -n "$old_default_remote" ] &&
                               [ -n "$default_remote" ] &&
                               [ "$old_default_remote" != "$default_remote" ] &&
                               [ "$remote" = "$old_default_remote" ] &&
                               git rev-parse --verify -q "$default_remote^{commit}" >/dev/null &&
                               git merge-base --is-ancestor "$local" "$default_remote" 2>/dev/null
                        then
                            default_local="${default_remote#origin/}"
                            warn "Switching from ${local#refs/heads/} to $default_local"
                            git remote set-head origin "$default_local" >/dev/null 2>&1 || :
                            git checkout "$default_local" || exit
                            local="$(git symbolic-ref HEAD 2>/dev/null)"
                            ret=0
                        fi
                        remote="$(git for-each-ref --format='%(upstream:short)' "$local" 2>/dev/null)"
                        # If local has been fastforwarded to upstream by hub sync, skip rebasing.
                        if [ -n "$remote" ]; then
                            if git rev-parse --verify -q "$remote^{commit}" >/dev/null; then
                                if [ "$ret" -eq 0 ] && [ -n "$(git rev-list --max-count 1 "$local..$remote")" ]; then
                                    git rebase "$remote" || exit
                                fi
                            else
                                warn "Upstream branch is gone: $remote"
                                warn "Unset it with: git branch --unset-upstream"
                                warn "Or set a new one with: git branch --set-upstream-to=<upstream>"
                                ret=1
                            fi
                        fi
                    fi
                    if [ -z "$update_failed" ] || [ "$ret" -ne 0 ]; then
                        cat "$update_log" >&2
                    fi
                    if command -v git-delete-merged >/dev/null; then
                        git-delete-merged
                    fi
                    if [ "$vcs" = git-svn ]; then
                        git svn rebase -l
                    fi
                    git submodule update --init --recursive
                    exit $ret
                } )
            ;;
        git-bare)
            echo "[Updating \`$file' with $vcs]"
            record_maintenance_target "$dir"
            ( setup; GIT_DIR="$dir" git -c gc.auto=0 -c maintenance.auto=false fetch )
            ;;
        hg)
            echo "[Updating \`$file' with $vcs]"
            if [ -d "$file" ]; then
                ( setup; cd "$file" && hg pull -u )
            else
                ( setup; cd "$dir" && {
                        hg pull
                        hg update "$file"
                    } )
            fi
            ;;
        bzr)
            echo "[Updating \`$file' with $vcs]"
            if [ -d "$file" ]; then
                ( setup; cd "$file" && bzr update && bzr merge )
            else
                ( setup; cd "$dir" && {
                        bzr update
                        bzr merge "$file"
                    } )
            fi
            ;;
        *)
            [ -z "$OPT_e" ] || return 0
            warn "Skipping \`$file'"
            ;;
    esac
}

subdirs_escaped () {
    local dir=$1 listfile excludelistfile tmpfile line exclude excluded

    [ -f "$dir/.sup" ] || return

    listfile="$(mktemp "$MYTMPDIR"/list.XXXXXX)"

    while read -r pat; do
        case "$pat" in
            ([#]*)
                continue
                ;;
            ([-\!]*)
                pat=${pat#?}
                excludelistfile="$(mktemp "$MYTMPDIR"/excludelist.XXXXXX)"
                tmpfile="$(mktemp "$MYTMPDIR"/tmp.XXXXXX)"
                eval "printf '%s\n' \$dir/$pat" > "$excludelistfile"
                while read -r line; do
                    excluded=
                    while read -r exclude; do
                        case "$line" in
                            "$exclude"|"$exclude"/*)
                                excluded=t
                                break
                                ;;
                        esac
                    done < "$excludelistfile"
                    [ -n "$excluded" ] || printf '%s\n' "$line"
                done < "$listfile" > "$tmpfile"
                mv "$tmpfile" "$listfile"
                rm -f "$excludelistfile"
                ;;
            ([+]*|*)
                eval "printf '%s\n' \$dir/$pat" >> "$listfile"
        esac
    done < "$dir/.sup"

    sort -u "$listfile" |
        while read -r subdir; do
            if [ -d "$subdir" -a ! -L "$subdir" ]; then
                printf ' %s' "$(sh_escape "$subdir")"
            fi
        done

    rm -f "$listfile"
}

vcs () {
    local file ret=0

    for file; do
        local vcs="$(vcs_of "$file")" 

        if [ -z "$vcs" ]; then
            warn "VCS unknown: $file"
            ret=1
        fi

        echo "$vcs"
    done

    return $ret
}

svn_upgrade () {
    local dir="$1" output
    if [ -f "$dir" ]; then
        dir="$(dirname "$dir")"
    fi
    (
        cd "$dir" || exit 1
        output="$(svn upgrade 2>&1)"
        case "$output" in
            '')
                exit
                ;;
            'svn: E155019:'*" root is '"*"'")
                svn upgrade "$(expr "$output" : ".* root is '\\(.*\\)'.*")"
                exit
                ;;
            *)
                exit 1
        esac
    )
}

svn_update () {
    local file="$1"
    ( cd "$(dirname "$file")" && svn up "$(basename "$file")" )
}

run_ruby () {
    local ruby
    for ruby in /usr/bin/ruby /usr/local/bin/ruby /usr/pkg/bin/ruby; do
        if [ -x "$ruby" ]; then
            "$ruby" "$@"
            return $?
        fi
    done

    ruby="$(cd && { mise which ruby || rtx which ruby || asdf which ruby || rbenv which ruby; } 2>/dev/null)"
    if [ -x "$ruby" ]; then
        "$ruby" "$@"
    else
        ruby "$@"
    fi
}

syncer () {
    if command -v git-sync >/dev/null; then
        echo git
    elif command -v hub >/dev/null; then
        echo hub
    else
        false
    fi
}

git_remote_update () {
    local syncer
    if ! git symbolic-ref refs/remotes/origin/HEAD >/dev/null 2>&1 &&
           ! git remote show origin | grep -q '^  HEAD branch: [^ (]'
    then
        warn "This repository seems to be empty."
        return 127
    fi
    if { command -v ruby && syncer="$(syncer)"; } >/dev/null; then
        run_ruby -e 'rs=`git remote`.split;m,=%w[upstream github origin]&rs|rs;m&&fork{puts"Fetching "<<m;exec"'"$syncer"' -c gc.auto=0 -c maintenance.auto=false sync"};(rs-[m]).each{|r|fork{exec *%w[git -c gc.auto=0 -c maintenance.auto=false remote update -p]<<r}};exit Process.waitall.map{|p,s|s.exitstatus}.max||0'
    elif xargs -P1 </dev/null >/dev/null 2>&1; then
        git remote | xargs -P5 -n1 git -c gc.auto=0 -c maintenance.auto=false remote update --prune
    else
        git -c gc.auto=0 -c maintenance.auto=false remote update --prune
    fi
}

record_maintenance_target () {
    printf '%s\n' "$1" >> "$MYTMPDIR/maint.list"
}

run_maintenance () {
    local listfile="$MYTMPDIR/maint.list" dir quiet=

    [ -f "$listfile" ] || return 0

    [ -z "$OPT_q$OPT_e" ] || quiet=--quiet

    sort -u "$listfile" | while IFS= read -r dir; do
        git -C "$dir" maintenance run --auto $quiet </dev/null || :
    done
}

setup_report () {
    [ -n "$OPT_report" ] || return 0

    : > "$OPT_report" || exit $?
}

report_status () {
    local file="$1" vcs="$2" ret="$3"

    [ -n "$OPT_report" ] || return 0

    printf '%s\t%s\t%s\n' "$(dir_of "$file")" "$vcs" "$ret" >> "$OPT_report" || exit $?
}

main "$@"
